# Market-Rover Frontend — Environment Variables
# Copy to .env and fill in values
# Vite requires the VITE_ prefix for vars exposed to the browser

# Backend API base URL
# Local dev (Vite proxy handles /api → localhost:8080, so this is optional locally)
VITE_API_URL=http://localhost:8080

# Google OAuth Client ID (public — safe for browser)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
