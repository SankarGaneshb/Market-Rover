# Market-Rover Backend — Required Environment Variables
# Copy to .env and fill in values — NEVER commit .env to Git

# --- Google Gemini (LangGraph agents) ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Database (PostgreSQL / Cloud SQL) ---
# Local dev:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/market_rover
# Cloud Run production (Cloud SQL connector — set via Cloud Run env vars, not here):
# CLOUD_SQL_CONNECTION_NAME=market-rover:us-central1:investbrand-db
# DB_USER=postgres
# DB_PASSWORD=your_prod_password
# DB_NAME=market_rover

# --- Security ---
JWT_SECRET=change_this_in_production

# --- Runtime ---
PORT=8080
NODE_ENV=development
